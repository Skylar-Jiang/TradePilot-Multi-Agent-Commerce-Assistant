# Railway staging template. Copy names into Railway Variables; do not commit real values.
APP_ENV=staging
APP_DEBUG=false
APP_NAME=TradePilot
APP_VERSION=0.1.0

# Replace these placeholders only after Railway and Vercel generate their real preview domains.
CORS_ALLOWED_ORIGINS=https://replace-with-vercel-preview.vercel.app
TRUSTED_HOSTS=healthcheck.railway.app,*.up.railway.app,*.railway.internal

# Attach one Railway Volume at /data before the first stateful staging run.
DATABASE_URL=sqlite:////data/tradepilot.db
CHROMA_DIR=/data/chroma
CHROMA_PERSIST_DIR=/data/chroma
UPLOAD_DIR=/data/uploads
REPORT_DIR=/data/reports
RAG_MANIFEST_PATH=/data/index-manifest.sqlite
PEER_CACHE_DIR=/data/peer-cache
TRADE_TARIFF_DB_PATH=/data/tariff-rules.sqlite

CHROMA_PRODUCT_COLLECTION=product_knowledge
CHROMA_REVIEW_COLLECTION=review_insight
PEER_METADATA_PATH=data/filtered/meta_pet_supplies_prefiltered.jsonl
PEER_REVIEWS_PATH=data/filtered/pet_supplies_reviews_prefiltered.jsonl
PEER_MATCH_CONFIG_PATH=config/peer_matching.yaml
TRADE_HS_MAPPING_PATH=config/trade/hs_mapping.yaml

DEFAULT_DATA_MODE=demo
RAG_USE_CHROMA=true
RUN_WORKER_COUNT=1
LOG_LEVEL=INFO

# Leave provider secrets empty for a public demo-only staging deployment.
# APP_API_KEY is reserved by Settings but is not currently enforced by the API.
APP_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

MODEL_FAST=qwen3.6-flash
MODEL_ANALYSIS=deepseek-v4-flash
MODEL_REPORT=qwen3.7-plus
MODEL_VISION=qwen3-vl-plus
EMBEDDING_MODEL=text-embedding-v4
RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANK_BASE_URL=https://api.siliconflow.com/v1
RERANK_ENABLED=false
