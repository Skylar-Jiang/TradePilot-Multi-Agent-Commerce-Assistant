APP_ENV=development
APP_DEBUG=false
APP_NAME=TradePilot
APP_VERSION=0.1.0
APP_API_KEY=

DATABASE_URL=sqlite:///data/demo/tradepilot_demo.db
CHROMA_DIR=data/demo/chroma
CHROMA_PERSIST_DIR=data/demo/chroma
CHROMA_PRODUCT_COLLECTION=product_knowledge
CHROMA_REVIEW_COLLECTION=review_insight
UPLOAD_DIR=data/demo/uploads
REPORT_DIR=data/demo/reports

# Real mode never falls back. These values are intentionally empty.
OPENAI_API_KEY=
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_FAST=qwen3.6-flash
MODEL_ANALYSIS=deepseek-v4-flash
MODEL_REPORT=qwen3.7-plus
MODEL_VISION=qwen3-vl-plus
MODEL_TEMPERATURE=0.1
MODEL_TIMEOUT_SECONDS=120
MODEL_MAX_RETRIES=1
MODEL_PARSE_MAX_RETRIES=1
MODEL_MAX_TOKENS=4096
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DEVICE=cpu
RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANK_BASE_URL=https://api.siliconflow.com/v1
RERANK_ENABLED=false
RERANK_REQUIRED=false
RERANK_POLICY=conditional
RERANK_PRODUCT_ENABLED=false
RERANK_REVIEW_ENABLED=true
RERANK_MIN_CANDIDATES=8
RERANK_MAX_CANDIDATES=20
RERANK_TIMEOUT_SECONDS=40
RERANK_MAX_RETRIES=3
RAG_USE_CHROMA=true
RAG_FETCH_K=30
RAG_PRODUCT_FETCH_K=30
RAG_REVIEW_FETCH_K=30
RAG_TOP_K=8
RAG_SCORE_THRESHOLD=0.0
RAG_MMR_ENABLED=true
RAG_MMR_LAMBDA=0.7
RAG_QUERY_MAX_RETRIES=3
RAG_QUERY_RETRY_DELAY_SECONDS=0.1
RAG_MAX_PER_SOURCE=3
RAG_MIN_PRODUCT_EVIDENCE=1
RAG_MIN_REVIEW_EVIDENCE=3
RAG_BATCH_SIZE=128
RAG_EMBEDDING_BATCH_SIZE=32
RAG_EMBEDDING_CONCURRENCY=4
RAG_INDEX_BATCH_SIZE=32
RAG_CHUNK_SIZE=2800
RAG_CHUNK_OVERLAP=300
RAG_MANIFEST_PATH=data/index_manifest.sqlite
PEER_METADATA_PATH=data/filtered/meta_pet_supplies_prefiltered.jsonl
PEER_REVIEWS_PATH=data/filtered/pet_supplies_reviews_prefiltered.jsonl
PEER_CACHE_DIR=data/demo/cache
PEER_MATCH_CONFIG_PATH=config/peer_matching.yaml
PEER_MAX_REVIEWS=300
RUN_WORKER_COUNT=2
SSE_POLL_INTERVAL_SECONDS=0.1
SSE_HEARTBEAT_SECONDS=10

DEFAULT_DATA_MODE=demo
LOG_LEVEL=INFO
