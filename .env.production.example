# Copy this file to .env.production. Keep real credentials only in the ignored shared .env.
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///data/production/tradepilot.db
CHROMA_DIR=data/production/chroma
CHROMA_PERSIST_DIR=data/production/chroma
UPLOAD_DIR=data/production/uploads
REPORT_DIR=data/production/reports
DEFAULT_DATA_MODE=real
RAG_USE_CHROMA=true
